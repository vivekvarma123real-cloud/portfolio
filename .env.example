PORT=3000
# Options: file | mongodb | mysql | postgresql
DB_TYPE=file

# MongoDB (default)
MONGODB_URI=mongodb://127.0.0.1:27017/riya_portfolio

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=riya_portfolio

# PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=riya_portfolio

# Contact form email (optional — messages are always saved in data/messages.json)
OWNER_EMAIL=tarparariya@gmail.com
GMAIL_USER=tarparariya@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Vercel production: use MongoDB Atlas (file storage does not persist on Vercel)
# DB_TYPE=mongodb
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/riya_portfolio
